# ============================================
# Genus install — required config
# ============================================

# Anthropic API key. Get one at console.anthropic.com.
# Without this, Genus boots but agent conversations will fail.
ANTHROPIC_API_KEY=

# Random secret Paperclip uses to sign session tokens. Any long random
# string works. Generate one with:
#     openssl rand -hex 32
# If you leave this blank, Genus falls back to an insecure dev value and
# starts anyway — fine for local testing, but change it before you rely
# on the install for real work.
BETTER_AUTH_SECRET=

# ============================================
# Optional — safe defaults for most people
# ============================================

# Port on your machine that Genus listens on. Change if 8080 is taken.
# PORT=8080

# Where Genus stores its data on your machine. Docker Compose maps this
# into the container as a persistent volume. You should never need to
# change this.
# BUS_ROOT=/app/bus
